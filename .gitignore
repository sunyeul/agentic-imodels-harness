# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
.ruff_cache/
.pytest_cache/
.mypy_cache/
.pyright/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Local OS/editor noise
.DS_Store

# Generated project-scoped competition data
projects/*/data/*
!projects/*/data/
!projects/*/data/.gitkeep
!projects/*/data/train.csv
!projects/*/data/valid.csv
!projects/*/data/test.csv
!projects/*/data/sample_submission.csv
!projects/*/data/metadata.json

# Generated project-scoped experiment outputs.
#
# Keep reviewable experiment records tracked so PRs can be reviewed by
# experiment unit:
# - blind or representation LoopRuns:
#   results/loop_runs/<loop_run_id>/{loop_manifest.json,iterations.csv,...}
# - run evidence referenced by those LoopRuns:
#   results/runs/<run_id>/{report.md,run_metadata.json,fold_metrics.json,...}
# - cross-condition summaries:
#   results/leaderboard.csv and any saved comparison artifacts.
#
# Submission files are generated delivery artifacts and can be recreated from a
# retained run, so keep them out of review diffs by default.
projects/*/results/submissions/*
!projects/*/results/
!projects/*/results/loop_runs/
!projects/*/results/runs/
!projects/*/results/submissions/
!projects/*/results/loop_runs/.gitkeep
!projects/*/results/runs/.gitkeep
!projects/*/results/submissions/.gitkeep

# Lightweight experiment audit journals
projects/*/experiments/journal/*
!projects/*/experiments/journal/
!projects/*/experiments/journal/.gitkeep
!projects/*/experiments/journal/*.md
